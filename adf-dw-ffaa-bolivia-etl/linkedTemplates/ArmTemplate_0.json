{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-dw-ffaa-bolivia-etl"
		},
		"ls_adls_bronze_silver_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_bronze_silver'"
		},
		"ls_adls_medallion_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_medallion'"
		},
		"ls_oltp_fuerzas_armadas_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_oltp_fuerzas_armadas'"
		},
		"ls_adls_bronze_silver_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sadwffaaboliviadatalake.dfs.core.windows.net/"
		},
		"ls_adls_medallion_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sadwffaaboliviadatalake.dfs.core.windows.net/"
		},
		"ls_oltp_fuerzas_armadas_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "server02-fuerzas-armadas-bolivia.database.windows.net"
		},
		"ls_oltp_fuerzas_armadas_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "erp-fuerzas-armadas-bolivia-2"
		},
		"ls_oltp_fuerzas_armadas_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "userSisGer"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/ls_adls_bronze_silver')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('ls_adls_bronze_silver_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('ls_adls_bronze_silver_accountKey')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ls_adls_medallion')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('ls_adls_medallion_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('ls_adls_medallion_accountKey')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ls_oltp_fuerzas_armadas')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('ls_oltp_fuerzas_armadas_properties_typeProperties_server')]",
					"database": "[parameters('ls_oltp_fuerzas_armadas_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('ls_oltp_fuerzas_armadas_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('ls_oltp_fuerzas_armadas_password')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/Parquet1')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_adls_medallion",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "Parquet",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"folderPath": "bronze/tbl_zonas",
						"fileSystem": "data-warehouse"
					},
					"compressionCodec": "snappy"
				},
				"schema": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_adls_medallion')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/Parquet2')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_adls_bronze_silver",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"p_folder": {
						"type": "string"
					}
				},
				"annotations": [],
				"type": "Parquet",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"folderPath": {
							"value": "@dataset().p_folder",
							"type": "Expression"
						},
						"fileSystem": "data-warehouse"
					},
					"compressionCodec": "snappy"
				},
				"schema": [
					{
						"name": "id_zona",
						"type": "INT32"
					},
					{
						"name": "nombre",
						"type": "UTF8"
					},
					{
						"name": "departamento",
						"type": "UTF8"
					},
					{
						"name": "frontera_con",
						"type": "UTF8"
					},
					{
						"name": "tipo_terreno",
						"type": "UTF8"
					},
					{
						"name": "altitud_msnm",
						"type": "INT32"
					},
					{
						"name": "nivel_riesgo",
						"type": "UTF8"
					},
					{
						"name": "acceso_carretero",
						"type": "BOOLEAN"
					}
				]
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_adls_bronze_silver')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/ds_oltp_tbl_zonas')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_oltp_fuerzas_armadas",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"p_table": {
						"type": "string"
					}
				},
				"annotations": [],
				"type": "AzureSqlTable",
				"schema": [
					{
						"name": "id_zona",
						"type": "int",
						"precision": 10
					},
					{
						"name": "nombre",
						"type": "nvarchar"
					},
					{
						"name": "departamento",
						"type": "nvarchar"
					},
					{
						"name": "frontera_con",
						"type": "nvarchar"
					},
					{
						"name": "tipo_terreno",
						"type": "varchar"
					},
					{
						"name": "altitud_msnm",
						"type": "int",
						"precision": 10
					},
					{
						"name": "nivel_riesgo",
						"type": "varchar"
					},
					{
						"name": "acceso_carretero",
						"type": "bit"
					}
				],
				"typeProperties": {
					"schema": "oltp",
					"table": {
						"value": "@dataset().p_table",
						"type": "Expression"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_oltp_fuerzas_armadas')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/p_ingesta_oltp_to_bronze')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "fe_ingesta_tablas",
						"type": "ForEach",
						"dependsOn": [],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@createArray('tbl_estructura_organizacional', 'tbl_unidades', 'tbl_rangos', 'tbl_especialidades', 'tbl_tipos_movimiento', 'tbl_tipos_operacion', 'tbl_zonas', 'tbl_efectivos', 'tbl_movimientos_personal', 'tbl_operaciones')",
								"type": "Expression"
							},
							"isSequential": true,
							"activities": [
								{
									"name": "Copy data2",
									"type": "Copy",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "AzureSqlSource",
											"queryTimeout": "02:00:00",
											"partitionOption": "None"
										},
										"sink": {
											"type": "ParquetSink",
											"storeSettings": {
												"type": "AzureBlobFSWriteSettings"
											},
											"formatSettings": {
												"type": "ParquetWriteSettings"
											}
										},
										"enableStaging": false,
										"translator": {
											"type": "TabularTranslator",
											"typeConversion": true,
											"typeConversionSettings": {
												"allowDataTruncation": true,
												"treatBooleanAsNumber": false
											}
										}
									},
									"inputs": [
										{
											"referenceName": "ds_oltp_tbl_zonas",
											"type": "DatasetReference",
											"parameters": {
												"p_table": "@item()"
											}
										}
									],
									"outputs": [
										{
											"referenceName": "Parquet2",
											"type": "DatasetReference",
											"parameters": {
												"p_folder": {
													"value": "@concat('bronze/',item())",
													"type": "Expression"
												}
											}
										}
									]
								}
							]
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": [],
				"lastPublishTime": "2026-06-03T21:12:13Z"
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/ds_oltp_tbl_zonas')]",
				"[concat(variables('factoryId'), '/datasets/Parquet2')]"
			]
		}
	]
}