{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-dw-ffaa-bolivia-etl"
		},
		"ls_adls_bronze_silver_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_bronze_silver'"
		},
		"ls_adls_medallion_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_medallion'"
		},
		"ls_oltp_fuerzas_armadas_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_oltp_fuerzas_armadas'"
		},
		"ls_adls_bronze_silver_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sadwffaaboliviadatalake.dfs.core.windows.net/"
		},
		"ls_adls_medallion_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sadwffaaboliviadatalake.dfs.core.windows.net/"
		},
		"ls_oltp_fuerzas_armadas_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "server02-fuerzas-armadas-bolivia.database.windows.net"
		},
		"ls_oltp_fuerzas_armadas_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "erp-fuerzas-armadas-bolivia-2"
		},
		"ls_oltp_fuerzas_armadas_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "userSisGer"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-dw-ffaa-bolivia-etl_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_bronze_silver_accountKey": {
						"value": "[parameters('ls_adls_bronze_silver_accountKey')]"
					},
					"ls_adls_medallion_accountKey": {
						"value": "[parameters('ls_adls_medallion_accountKey')]"
					},
					"ls_oltp_fuerzas_armadas_password": {
						"value": "[parameters('ls_oltp_fuerzas_armadas_password')]"
					},
					"ls_adls_bronze_silver_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_bronze_silver_properties_typeProperties_url')]"
					},
					"ls_adls_medallion_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_medallion_properties_typeProperties_url')]"
					},
					"ls_oltp_fuerzas_armadas_properties_typeProperties_server": {
						"value": "[parameters('ls_oltp_fuerzas_armadas_properties_typeProperties_server')]"
					},
					"ls_oltp_fuerzas_armadas_properties_typeProperties_database": {
						"value": "[parameters('ls_oltp_fuerzas_armadas_properties_typeProperties_database')]"
					},
					"ls_oltp_fuerzas_armadas_properties_typeProperties_userName": {
						"value": "[parameters('ls_oltp_fuerzas_armadas_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}